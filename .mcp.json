{
  "mcpServers": {
    "oxygen-agent": {
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://oxygen-agent.com/mcp",
        "--header",
        "Authorization: Bearer ${OXYGEN_API_KEY}"
      ]
    },
    "lemlist": {
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://app.lemlist.com/mcp",
        "--header",
        "X-API-Key: ${LEMLIST_API_KEY}"
      ]
    }
  }
}
