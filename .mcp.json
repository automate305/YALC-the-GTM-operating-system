{
  "mcpServers": {
    "smartlead": {
      "command": "npx",
      "args": ["-y", "smartlead-mcp-by-leadmagic"],
      "env": {
        "SMARTLEAD_API_KEY": "${SMARTLEAD_API_KEY}"
      }
    },
    "lemlist": {
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://app.lemlist.com/mcp",
        "--header",
        "X-API-Key: ${LEMLIST_API_KEY}"
      ]
    }
  }
}
